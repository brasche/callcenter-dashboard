# ── BlueRock API ──────────────────────────────────────────────────────────────
BLUEROCK_API_KEY=your_bluerock_api_key_here
BLUEROCK_API_URL=https://api.1bluerock.com/v2
# Optional: comma-separated queue names (e.g. Sales,Support)
# Leave blank to auto-discover all queues via /queues/list
BLUEROCK_QUEUES=

# ── Google Sheets ─────────────────────────────────────────────────────────────
# The ID from your spreadsheet URL:
# https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID_HERE/edit
GOOGLE_SHEETS_ID=your_google_sheets_id_here

# On Railway (or any server): paste the ENTIRE contents of credentials.json here
# as a single-line JSON string (minified). Leave blank if using a local file.
GOOGLE_SHEETS_CREDENTIALS_JSON=

# Local dev only: path to your service account JSON file.
# Ignored when GOOGLE_SHEETS_CREDENTIALS_JSON is set.
GOOGLE_SHEETS_CREDENTIALS_FILE=credentials.json

# Tab names in the spreadsheet
GOOGLE_SHEETS_TAB=Form Responses 1
GOOGLE_SHEETS_AGENTS_TAB=Active Agents
GOOGLE_SHEETS_HEADER_ROW=1

# Column indices (0-based) in the "Form Responses 1" tab:
# A=0 Status, B=1 Timestamp, C=2 Client Name, D=3 Backend,
# E=4 Enrolled Date, F=5 Agent Name, G=6 Client ID (phone), H=7 Debt Amount
# I=8 First Payment Date, J=9 First Payment Amount
GOOGLE_SHEETS_COL_STATUS=0
GOOGLE_SHEETS_COL_TIMESTAMP=1
GOOGLE_SHEETS_COL_CLIENT_NAME=2
GOOGLE_SHEETS_COL_CLOSE_DATE=4
GOOGLE_SHEETS_COL_AGENT=5
GOOGLE_SHEETS_COL_PHONE=6
GOOGLE_SHEETS_COL_DEAL_VALUE=7
GOOGLE_SHEETS_COL_FIRST_PAYMENT=9

# ── Database ──────────────────────────────────────────────────────────────────
# On Railway: DATABASE_URL is injected automatically when you add a Postgres plugin.
# Locally: run a local Postgres and set this.
DATABASE_URL=postgresql://user:password@localhost:5432/callcenter

# ── Sync intervals (seconds) ──────────────────────────────────────────────────
BLUEROCK_SYNC_INTERVAL=30
SHEETS_SYNC_INTERVAL=300
